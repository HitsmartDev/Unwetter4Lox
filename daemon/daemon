#!/bin/bash
# Unwetter4Lox – Daemon-Control-Script
# WICHTIG: REPLACELBHOMEDIR und REPLACELBPPLUGINDIR werden vom LoxBerry-Installer
# bei der Installation durch die tatsächlichen Pfade ersetzt (keine Hardcodes nötig)

LBHOMEDIR="REPLACELBHOMEDIR"
LBPPLUGINDIR="REPLACELBPPLUGINDIR"
PYTHON=$(which python3)
DAEMON="${LBHOMEDIR}/bin/plugins/${LBPPLUGINDIR}/unwetter4lox_daemon.py"
PIDFILE="${LBHOMEDIR}/log/plugins/${LBPPLUGINDIR}/daemon.pid"
LOGDIR="${LBHOMEDIR}/log/plugins/${LBPPLUGINDIR}"

export LBHOMEDIR LBPPLUGINDIR

_stop_all() {
    # PID-Datei zuerst versuchen
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID" 2>/dev/null
            sleep 1
            # Notfall-SIGKILL wenn Prozess noch läuft
            kill -0 "$PID" 2>/dev/null && kill -9 "$PID" 2>/dev/null || true
        fi
        rm -f "$PIDFILE"
    fi
    # Immer auch nach weiteren Instanzen suchen (verhindert Zombie-Prozesse nach fehlerhaftem Stop)
    pkill -f "unwetter4lox_daemon.py" 2>/dev/null || true
    sleep 1
}

case "$1" in
    start)
        CFGFILE="${LBHOMEDIR}/config/plugins/${LBPPLUGINDIR}/unwetter4lox.cfg"
        if [ ! -f "$CFGFILE" ]; then
            echo "Fehler: Konfigurationsdatei fehlt."
            exit 1
        fi
        LAT=$(grep "^LAT=" "$CFGFILE" | cut -d= -f2 | tr -d ' ' | tr -d '\r')
        LON=$(grep "^LON=" "$CFGFILE" | cut -d= -f2 | tr -d ' ' | tr -d '\r')
        if [ -z "$LAT" ] || [ -z "$LON" ]; then
            echo "Fehler: Standort nicht konfiguriert (LAT/LON fehlen)."
            exit 1
        fi

        # Sicherstellen dass keine alte Instanz mehr läuft
        if [ -f "$PIDFILE" ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null; then
            echo "Daemon laeuft bereits (PID $(cat $PIDFILE))"
            exit 0
        fi
        # Eventuelle Zombie-Prozesse aufräumen
        pkill -f "unwetter4lox_daemon.py" 2>/dev/null || true
        sleep 1

        mkdir -p "${LOGDIR}"
        chown loxberry:loxberry "${LOGDIR}" 2>/dev/null || true
        rm -f "$PIDFILE"
        nohup $PYTHON "$DAEMON" > /dev/null 2>&1 &
        echo $! > "$PIDFILE"
        echo "Unwetter4Lox gestartet (PID $!)"
        ;;
    stop)
        _stop_all
        echo "gestoppt"
        ;;
    restart)
        _stop_all
        sleep 2
        $0 start
        ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null; then
            echo "running"
        else
            echo "stopped"
        fi
        ;;
    *)
        echo "Verwendung: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
exit 0
