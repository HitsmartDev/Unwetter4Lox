#!/bin/bash
# Unwetter4Lox uninstall – wird von LoxBerry beim Deinstallieren aufgerufen

PLUGIN="unwetter4lox"

# LBHOMEDIR ermitteln
if [ -z "$LBHOMEDIR" ]; then
    LBHOMEDIR=$(grep "^LBHOMEDIR=" /etc/environment 2>/dev/null | head -1 | cut -d= -f2 | tr -d '"' | tr -d "'")
fi
LBHOMEDIR=${LBHOMEDIR:-/opt/loxberry}

echo "<INFO> Unwetter4Lox wird deinstalliert..."

# Daemon stoppen
DAEMONSCRIPT="${LBHOMEDIR}/system/daemons/plugins/${PLUGIN}"
if [ -x "${DAEMONSCRIPT}" ]; then
    echo "<INFO> Daemon wird gestoppt..."
    "${DAEMONSCRIPT}" stop 2>/dev/null || true
    echo "<OK> Daemon gestoppt"
fi

# Sudoers-Datei entfernen
SUDOERS="/etc/sudoers.d/${PLUGIN}"
if [ -f "${SUDOERS}" ]; then
    rm -f "${SUDOERS}"
    echo "<OK> Sudoers entfernt: ${SUDOERS}"
fi

# Alle Plugin-Verzeichnisse werden von LoxBerry automatisch nach diesem Script entfernt
# (bin, config, data, log, webfrontend)

echo "<OK> Unwetter4Lox Deinstallation abgeschlossen"
exit 0
